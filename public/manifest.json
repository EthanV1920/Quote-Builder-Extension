{
  "manifest_version": 3,
  "name": "Quote Builder",
  "version": "0.1.0",
  "description": "Capture B&H product details and append them to Google Sheets.",
  "permissions": ["storage", "tabs", "activeTab", "scripting"],
  "host_permissions": [
    "https://www.bhphotovideo.com/*",
    "https://bhphotovideo.com/*",
    "https://www.amazon.com/*",
    "https://amazon.com/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Quote Builder"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+Q",
        "mac": "Alt+Shift+Q"
      },
      "description": "Open the Quote Builder popup"
    }
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://www.bhphotovideo.com/c/product/*",
        "https://bhphotovideo.com/c/product/*",
        "https://www.amazon.com/*",
        "https://amazon.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
